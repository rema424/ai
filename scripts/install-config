#!/usr/bin/env sh
set -eu

codex_home="${CODEX_HOME:-"$HOME/.codex"}"
config_file="$codex_home/config.toml"
marker='spiral-autonomy counts as explicit authorization'

is_top_level_installed() {
  awk '
    /^[[:space:]]*\[/ { exit 1 }
    /^[[:space:]]*developer_instructions[[:space:]]*=/ { found = 1; exit 0 }
    END { exit found ? 0 : 1 }
  ' "$config_file"
}

if [ -f "$config_file" ] && grep -Fq "$marker" "$config_file" && is_top_level_installed; then
  echo "spiral-autonomy developer_instructions are already installed in $config_file"
  exit 0
fi

if [ -f "$config_file" ] && grep -Eq '^[[:space:]]*developer_instructions[[:space:]]*=' "$config_file" && ! grep -Fq "$marker" "$config_file"; then
  echo "developer_instructions already exists in $config_file"
  echo "Leaving the file unchanged. Merge the block from docs/setup.md manually."
  exit 1
fi

mkdir -p "$codex_home"
touch "$config_file"

backup_file="$config_file.bak.$(date +%Y%m%d%H%M%S)"
cp "$config_file" "$backup_file"
tmp_file="$config_file.tmp.$$"

{
  printf 'developer_instructions = """\n'
  printf "The user's invocation of \$spiral-autonomy counts as explicit authorization for subagents, delegation, and parallel agent work.\n"
  printf '\n'
  printf 'When spiral-autonomy is active, use the maximum useful parallelism available by default.\n'
  printf 'Keep subagents continuously supplied with bounded concrete tasks until the mission objective is achieved or a real stop condition is reached.\n'
  printf '\n'
  printf 'Do not use subagents as generic search engines.\n'
  printf 'Assign high-load research, design, implementation, testing, review, validation, or risk-analysis outputs.\n'
  printf 'Keep the critical path local, avoid duplicate work, and give implementation workers disjoint write scopes.\n'
  printf '"""\n'
  printf '\n'
  if grep -Fq "$marker" "$config_file"; then
    awk '
      /^[[:space:]]*developer_instructions[[:space:]]*=[[:space:]]*"""[[:space:]]*$/ { skip = 1; next }
      skip && /^[[:space:]]*"""[[:space:]]*$/ { skip = 0; next }
      !skip { print }
    ' "$config_file"
  else
    cat "$config_file"
  fi
} > "$tmp_file"

mv "$tmp_file" "$config_file"

echo "Installed spiral-autonomy developer_instructions in $config_file"
echo "Backup written to $backup_file"
echo "Start a new Codex session for the change to take effect."
